{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "store:default",
    "core:window:allow-set-title",
    "core:webview:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "mail-analyzer", "cmd": "", "args": true }]
    }
  ]
}
